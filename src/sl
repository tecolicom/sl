#!/usr/bin/env bash

# sl - sl runs across your terminal
#
# Usage: sl [options] [VERSION|SUBCOMMAND]
#
# Options:
#   -a, --all            Sweep the entire screen (2026)
#   -s, --stop           Stop at existing text instead of sweeping (2026)
#   -t, --streak         Enable streak effect (2026, default)
#   -T, --no-streak      Disable streak effect (2026)
#   -c, --color=MODE     Color mode: truecolor/24bit/256
#   -p, --param=K=V      Set coupler parameter (e.g., STREAK=rumble)
#   -d, --debug          Show debug info on the last line before running
#   -n, --dryrun         Dry run (show debug info and exit)
#   -h, --help           Show help
#       --version        Show version
#
# Subcommands:
#   capture     Dump captured screen text
#   sweep-area  Show the 7-line area where SL runs
#   clear-col   Print the column where sweeping should start
#   debug       Show detailed sweep area analysis
#   mark        Draw a visual marker at the sweep start column
#
# Versions:
#   2023        Unicode art version, always sweeps
#   2010        Direct terminal control version
#   1985        Original curses version with retro delay

##############################################################################
# Setup
##############################################################################

# Resolve symlink to find the real script location
self=$0
if [ -L "$self" ]; then
    link=$(readlink "$self")
    case "$link" in
        /*) self=$link ;;
        *)  self=$(dirname "$self")/$link ;;
    esac
fi
selfdir=$(dirname "$self")
if [ -d "$selfdir/../libexec/sl-classic" ]; then
    bindir=$selfdir/../libexec/sl-classic
else
    bindir=$selfdir
fi
PATH=$bindir:$PATH

##############################################################################
# Functions
##############################################################################

warn()  { echo "sl: $*" >&2; }
error() { warn "$@"; exit 1; }

# Callback functions for getoptlong
help()    { sed -n '3,/^$/{ s/^# \{0,1\}//; p; }' "$self"; exit 0; }
version() { echo "$VERSION"; exit 0; }
nostreak() { [[ $2 ]] && streak= || streak=1; }

# Find the latest available version
resolve_latest() {
    local v
    for v in 2026 2023 2010 1985; do
        if command -v "sl-$v" >/dev/null 2>&1; then
            echo "$v"
            return
        fi
    done
    echo 2023
}

# Output filter for sl-1985: add per-character delay for retro feel.
# Strips smcup/rmcup sequences to prevent alternate screen switching.
slowout() {
    PERL_BADLANG=0 perl -e '
        $|=1;
        my $delay = 0.0005;
        my %skip;
        for my $cap (qw(smcup rmcup)) {
            my $s = `tput $cap 2>/dev/null`;
            $skip{$s} = 1 if length $s;
        }
        while (sysread(STDIN, my $c, 1)) {
            if ($c eq "\e") {
                my $seq = $c;
                sysread(STDIN, $c, 1) or last;
                $seq .= $c;
                if ($c eq "[" || $c eq "(") {
                    while (sysread(STDIN, $c, 1)) {
                        $seq .= $c;
                        last if $c =~ /[A-Za-z]/;
                    }
                }
                print $seq unless $skip{$seq};
            } else {
                print $c;
                select(undef, undef, undef, $delay);
            }
        }
    '
}

##############################################################################
# Argument parsing
##############################################################################

VERSION=v2026.2
USAGE="sl [options] [VERSION|SUBCOMMAND]"

declare -A OPTS=(
    [&USAGE]="$USAGE" [&DELIM]=
    [     help | h  !  # show help             ]=
    [  version |    !  # show version           ]=
    [    debug | d     # debug mode             ]=
    [   dryrun | n     # dry-run mode           ]=
    [      all | a     # sweep all (2026)       ]=
    [     stop | s     # stop at text           ]=
    [   streak | t     # enable streak (2026)   ]=1
    [ nostreak | T  !  # disable streak         ]=
    [    color | c  :  # color mode             ]=
    [    param | p  %  # coupler parameter      ]=
)

. getoptlong.sh OPTS "$@"

subcmd=${1:-}
case "$subcmd" in
    2026|2023|2010|1985)
        version=$subcmd
        shift
        ;;
    capture|clear-col|debug|mark|sweep-area)
        shift
        ;;
    *)
        version=$(resolve_latest)
        ;;
esac

##############################################################################
# Version-specific functions
##############################################################################

# Run sl-2026 with sweep detection.
sl_2026() {
    . sl-sweep.sh
    if [[ $all ]]; then
        export SL_SWEEP_ALL=1
    fi
    local clear_col=9999
    if [[ $all ]]; then
        col=$(get_visible_screen | calc_max_display_col)
    else
        col=$(calc_clear_col)
    fi
    if [[ -n "$col" ]] && ((col >= 0)); then
        clear_col=$col
    fi
    if [[ $debug || $dryrun ]]; then
        get_terminal_size
        printf "========== %s %s %s %sx%s %s" \
            "${TERM:-}" "${TERM_PROGRAM:-}" "${LANG:-}" "$TERM_COLS" "$TERM_LINES" "$clear_col"
        [[ $dryrun ]] && { echo; return; }
    fi
    export SL_SWEEP_COL=$clear_col
    if [[ $stop ]]; then
        export SL_STOP_COL=$clear_col
    fi
    if [[ $streak ]]; then
        export SL_CAR_STREAK=1
    else
        export SL_CAR_STREAK=0
    fi
    if [[ ${param[STREAK]:-} ]]; then
        IFS=, read -ra _modes <<< "${param[STREAK]}"
        for _m in "${_modes[@]}"; do
            export "SL_STREAK_${_m^^}=1"
        done
    fi
    if [[ $color ]]; then
        case $color in
            truecolor|24bit) export COLORTERM=truecolor ;;
            256)             unset COLORTERM ;;
            *)               error "unknown color mode: $color" ;;
        esac
    fi
    exec sl-$version "$@"
}

# Run sl-1985 via script(1) with per-character delay output.
# sl-1985 uses curses and needs a pty; use script(1) to provide one.
sl_1985() {
    if script --help 2>&1 | grep -q -- '--command'; then
        script -qc sl-1985 /dev/null
    else
        script -q /dev/null sl-1985 "$@"
    fi | slowout
}

##############################################################################
# Subcommand dispatch (all exit here)
##############################################################################

case "$subcmd" in
    capture|sweep-area|clear-col|debug|mark)
        . sl-sweep.sh
        ;;
esac

case "$subcmd" in
    capture)
        get_visible_screen || { error "Failed to capture screen text."; }
        exit 0
        ;;
    sweep-area)
        get_sweep_area || { error "Failed to capture screen text."; }
        exit 0
        ;;
    clear-col)
        clear_col=$(calc_clear_col) || { error "Failed to calculate clear column."; }
        printf '%s\n' "$clear_col"
        exit 0
        ;;
    debug)
        debug_capture_and_col
        exit $?
        ;;
    mark)
        clear_col=$(calc_clear_col) || { error "Failed to calculate clear column."; }
        draw_column_marker "$clear_col"
        printf '%s\n' "$clear_col"
        exit 0
        ;;
esac

##############################################################################
# Run the selected version
##############################################################################

if declare -f "sl_$version" >/dev/null 2>&1; then
    "sl_$version" "$@"
else
    exec sl-$version "$@"
fi
