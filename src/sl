#!/bin/bash

# sl - Steam Locomotive wrapper script
#
# Dispatches to versioned sl binaries (sl-1985, sl-2010, sl-2023, sl-2026).
# The sl-2026 version detects existing text on the terminal screen and
# begins sweeping (pushing text off via dch2) only when the train reaches it.
#
# Usage: sl [-d] [VERSION|SUBCOMMAND] [ARGS...]
#
# Options:
#   -d          Show debug info on the last line before running
#
# Version-specific options (sl 2026):
#   -a          Sweep the entire screen
#
# Subcommands:
#   capture     Dump captured screen text
#   sweep-area  Show the 7-line area where SL runs
#   clear-col   Print the column where sweeping should start
#   debug       Show detailed sweep area analysis
#   mark        Draw a visual marker at the sweep start column

##############################################################################
# Setup
##############################################################################

# Resolve symlink to find the real script location
self=$0
if [ -L "$self" ]; then
    link=$(readlink "$self")
    case "$link" in
        /*) self=$link ;;
        *)  self=$(dirname "$self")/$link ;;
    esac
fi
selfdir=$(dirname "$self")
if [ -d "$selfdir/../libexec/sl-classic" ]; then
    bindir=$selfdir/../libexec/sl-classic
else
    bindir=$selfdir
fi
PATH=$bindir:$PATH

##############################################################################
# Functions
##############################################################################

warn()  { echo "sl: $*" >&2; }
error() { warn "$@"; exit 1; }

# Show help and exit
show_help() {
    man sl 2>/dev/null || echo "Usage: sl [-dna] [version|subcommand] [options]"
    exit 0
}

# Handle a long option from getopts -: pattern
handle_long_opt() {
    case "$1" in
        help)    show_help ;;
        version) echo "$VERSION"; exit 0 ;;
        *)       error "unknown option: --$1" ;;
    esac
}

# Find the latest available version
resolve_latest() {
    local v
    for v in 2026 2023 2010 1985; do
        if command -v "sl-$v" >/dev/null 2>&1; then
            echo "$v"
            return
        fi
    done
    echo 2023
}

# Output filter for sl-1985: add per-character delay for retro feel.
# Strips smcup/rmcup sequences to prevent alternate screen switching.
slowout() {
    PERL_BADLANG=0 perl -e '
        $|=1;
        my $delay = 0.0005;
        my %skip;
        for my $cap (qw(smcup rmcup)) {
            my $s = `tput $cap 2>/dev/null`;
            $skip{$s} = 1 if length $s;
        }
        while (sysread(STDIN, my $c, 1)) {
            if ($c eq "\e") {
                my $seq = $c;
                sysread(STDIN, $c, 1) or last;
                $seq .= $c;
                if ($c eq "[" || $c eq "(") {
                    while (sysread(STDIN, $c, 1)) {
                        $seq .= $c;
                        last if $c =~ /[A-Za-z]/;
                    }
                }
                print $seq unless $skip{$seq};
            } else {
                print $c;
                select(undef, undef, undef, $delay);
            }
        }
    '
}

##############################################################################
# Argument parsing
##############################################################################

VERSION=v2026.1
global_opts="dhn"

debug_flag=0
dryrun=0
passthru=()
OPTIND=1
while getopts ":${global_opts}-:" opt; do
    case "$opt" in
        d) debug_flag=1 ;;
        h) show_help ;;
        n) dryrun=1 ;;
        -) handle_long_opt "$OPTARG" ;;
        '?') passthru+=("-$OPTARG") ;;
    esac
done
shift $((OPTIND - 1))
set -- "${passthru[@]}" "$@"

subcmd=${1:-}
case "$subcmd" in
    2026|2023|2010|1985)
        version=$subcmd
        shift
        ;;
    capture|clear-col|debug|mark|sweep-area)
        shift
        ;;
    *)
        version=$(resolve_latest)
        ;;
esac

##############################################################################
# Version-specific functions
##############################################################################

# Run sl-2026 with sweep detection and optional flags.
#   -a  Sweep the entire screen (SL_SWEEP_ALL)
sl_2026() {
    local OPTIND opt sweep_all=0
    while getopts ":${global_opts}a-:" opt; do
        case "$opt" in
            [$global_opts]) ;;
            a) sweep_all=1 ;;
            -) handle_long_opt "$OPTARG" ;;
            '?') error "unknown option: -$OPTARG" ;;
        esac
    done
    shift $((OPTIND - 1))

    . sl-sweep.sh
    if ((sweep_all)); then
        export SL_SWEEP_ALL=1
    fi
    local clear_col=9999
    if ((sweep_all)); then
        col=$(get_visible_screen | calc_max_display_col)
    else
        col=$(calc_clear_col)
    fi
    if [[ -n "$col" ]] && ((col >= 0)); then
        clear_col=$col
    fi
    if ((debug_flag || dryrun)); then
        get_terminal_size
        printf "========== %s %s %s %sx%s %s" \
            "${TERM:-}" "${TERM_PROGRAM:-}" "${LANG:-}" "$TERM_COLS" "$TERM_LINES" "$clear_col"
        ((dryrun)) && { echo; return; }
    fi
    SL_SWEEP_COL=$clear_col exec sl-$version "$@"
}

# Run sl-1985 via script(1) with per-character delay output.
# sl-1985 uses curses and needs a pty; use script(1) to provide one.
sl_1985() {
    if script --help 2>&1 | grep -q -- '--command'; then
        script -qc sl-1985 /dev/null
    else
        script -q /dev/null sl-1985 "$@"
    fi | slowout
}

##############################################################################
# Subcommand dispatch (all exit here)
##############################################################################

case "$subcmd" in
    capture|sweep-area|clear-col|debug|mark)
        . sl-sweep.sh
        ;;
esac

case "$subcmd" in
    capture)
        get_visible_screen || { error "Failed to capture screen text."; }
        exit 0
        ;;
    sweep-area)
        get_sweep_area || { error "Failed to capture screen text."; }
        exit 0
        ;;
    clear-col)
        clear_col=$(calc_clear_col) || { error "Failed to calculate clear column."; }
        printf '%s\n' "$clear_col"
        exit 0
        ;;
    debug)
        debug_capture_and_col
        exit $?
        ;;
    mark)
        clear_col=$(calc_clear_col) || { error "Failed to calculate clear column."; }
        draw_column_marker "$clear_col"
        printf '%s\n' "$clear_col"
        exit 0
        ;;
esac

##############################################################################
# Run the selected version
##############################################################################

if declare -f "sl_$version" >/dev/null 2>&1; then
    "sl_$version" "$@"
else
    exec sl-$version "$@"
fi
